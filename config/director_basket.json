  "Command": {
    "check_truenas": {
      "object_name": "check_truenas",
      "object_type": "object",
      "command": "PluginDir + /check_truenas_extended_play.py",
      "arguments": {
        "-H": {
          "description": "TrueNAS hostname or IP address",
          "required": true,
          "value": "$truenas_hostname$"
        },
        "-p": {
          "description": "API key",
          "required": true,
          "value": "$truenas_apikey$"
        },
        "-t": {
          "description": "Check type",
          "required": true,
          "value": "$truenas_type$"
        },
        "-nv": {
          "description": "Skip SSL certificate verification",
          "set_if": "$truenas_no_verify_cert$"
        },
        "-zp": {
          "description": "Enable perfdata output",
          "set_if": "$truenas_perfdata$"
        },
        "-ig": {
          "description": "Ignore dismissed alerts",
          "set_if": "$truenas_ignore_dismissed$"
        },
        "-pn": {
          "description": "ZPool name filter",
          "set_if": "$truenas_zpoolname$",
          "value": "$truenas_zpoolname$"
        },
        "-zw": {
          "description": "ZPool/dataset warning threshold %",
          "set_if": "$truenas_zpool_warn$",
          "value": "$truenas_zpool_warn$"
        },
        "-zc": {
          "description": "ZPool/dataset critical threshold %",
          "set_if": "$truenas_zpool_crit$",
          "value": "$truenas_zpool_crit$"
        },
        "-cw": {
          "description": "CPU warning threshold %",
          "set_if": "$truenas_cpu_warn$",
          "value": "$truenas_cpu_warn$"
        },
        "-cc": {
          "description": "CPU critical threshold %",
          "set_if": "$truenas_cpu_crit$",
          "value": "$truenas_cpu_crit$"
        },
        "-mw": {
          "description": "Memory warning threshold %",
          "set_if": "$truenas_mem_warn$",
          "value": "$truenas_mem_warn$"
        },
        "-mc": {
          "description": "Memory critical threshold %",
          "set_if": "$truenas_mem_crit$",
          "value": "$truenas_mem_crit$"
        },
        "-nw": {
          "description": "Network warning threshold Kbit/s",
          "set_if": "$truenas_net_warn$",
          "value": "$truenas_net_warn$"
        },
        "-nc": {
          "description": "Network critical threshold Kbit/s",
          "set_if": "$truenas_net_crit$",
          "value": "$truenas_net_crit$"
        },
        "-u": {
          "description": "Username for password-based login",
          "set_if": "$truenas_user$",
          "value": "$truenas_user$"
        },
        "-ns": {
          "description": "Disable SSL (use ws:// instead of wss://)",
          "set_if": "$truenas_no_ssl$"
        },
        "-d": {
          "description": "Enable debug output",
          "set_if": "$truenas_debug$"
        }
      },
      "fields": [
        {
          "datafield_id": 1,
          "is_required": "y",
          "var_filter": null
        },
        {
          "datafield_id": 2,
          "is_required": "y",
          "var_filter": null
        },
        {
          "datafield_id": 3,
          "is_required": "y",
          "var_filter": null
        },
        {
          "datafield_id": 5,
          "is_required": "n",
          "var_filter": null
        },
        {
          "datafield_id": 19,
          "is_required": "n",
          "var_filter": null
        }
      ]
    }
  },
